{
  "compilerOptions": {
    "rootDir": ".",
    "paths": {
      "src/*": ["./src/*"]
    },
    "types": ["node", "jest"],
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ESNext",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "lib": ["DOM", "ESNext"],
    "skipLibCheck": false
  },
  "include": ["**/*.ts"]
}
